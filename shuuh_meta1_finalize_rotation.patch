diff --git a/backend/scripts/reset-data.js b/backend/scripts/reset-data.js
new file mode 100644
index 0000000..e42e728
--- /dev/null
+++ b/backend/scripts/reset-data.js
@@ -0,0 +1,61 @@
+// One-off maintenance script.
+//
+// 1) Drops the stale `simple_queue` table (leftover from the retired "энгийн
+//    эргэлт" feature — no longer created or read by the app, but old installs
+//    still have it on disk).
+// 2) Wipes ALL registered citizen accounts, ALL long-queue (урт хугцааны
+//    эргэлт) bookings, and ALL feedback (санал хүсэлт).
+//
+// This does NOT touch: admins, news, about_info.
+//
+// IMPORTANT: JWT tokens are self-contained and are not checked against the
+// database on each request (see backend/src/util/auth.js). Citizens who are
+// still logged in will keep working until their token expires (30 days) even
+// after their row is deleted here — deleting the row does not "log them out".
+// If you need to force everyone out immediately, rotate JWT_SECRET in your
+// .env file and restart the server; that invalidates every existing token
+// (admin sessions too).
+//
+// Usage (from the backend/ folder):
+//   node scripts/reset-data.js
+//
+// Make a backup first if you might need this data later:
+//   cp backend/data/khovd457.db backend/data/khovd457.db.bak
+
+const db = require('../src/db');
+
+function tableExists(name) {
+  return !!db.prepare("SELECT name FROM sqlite_master WHERE type='table' AND name = ?").get(name);
+}
+
+db.exec('BEGIN');
+try {
+  if (tableExists('simple_queue')) {
+    db.exec('DROP TABLE simple_queue');
+    console.log('Dropped stale simple_queue table.');
+  } else {
+    console.log('simple_queue table not present — nothing to drop.');
+  }
+
+  const counts = {
+    users: db.prepare('SELECT COUNT(*) as c FROM users').get().c,
+    long_queue: db.prepare('SELECT COUNT(*) as c FROM long_queue').get().c,
+    feedback: db.prepare('SELECT COUNT(*) as c FROM feedback').get().c,
+  };
+
+  db.exec('DELETE FROM users');
+  db.exec('DELETE FROM long_queue');
+  db.exec('DELETE FROM feedback');
+
+  // Reset autoincrement counters so new records start from id=1 again.
+  db.exec("DELETE FROM sqlite_sequence WHERE name IN ('users', 'long_queue', 'feedback')");
+
+  db.exec('COMMIT');
+
+  console.log('Deleted:', counts);
+  console.log('Done. users, long_queue, and feedback are now empty. admins/news/about_info were left untouched.');
+} catch (e) {
+  db.exec('ROLLBACK');
+  console.error('Reset failed, rolled back. Error:', e.message);
+  process.exit(1);
+}
